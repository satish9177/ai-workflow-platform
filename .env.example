DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=60000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=30000
DB_CONNECTION_HOLD_WARN_SECONDS=5
ARQ_MAX_JOBS=10
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
